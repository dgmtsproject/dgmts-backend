# Copy to .env on the server (or merge with your existing .env)
FLASK_SECRET_KEY=change-me
EMAIL_USERNAME=your-smtp@example.com
EMAIL_PASSWORD=app-password

# Main instrumentation DB (unchanged) — still Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=xxxxx

# --- Migration only (local Postgres). Unrelated to send-mail, which still uses DGMTS Static Supabase below. ---
STATIC_DB_HOST=127.0.0.1
STATIC_DB_PORT=5432
STATIC_DB_NAME=dgmts_static_db
STATIC_DB_USER=dgmts_static_user
STATIC_DB_PASSWORD=your-secure-password

# Public base URL of this same Flask app (for links to /api/dgmts-static/media/...)
STATIC_APP_PUBLIC_BASE=https://imsite.dullesgeotechnical.com

# Where to store uploaded public images (subfolders: newsletter-images, blog-images, event-images)
STATIC_MEDIA_DIR=static_media

# Blog links in notify-subscribers emails
BLOG_BASE_URL=https://dullesgeotechnical.com/blog
ADMIN_EMAIL=info@dullesgeotechnical.com

# --- Unchanged: DGMTS static site project in Supabase (send-mail, etc.) ---
# DGMTS_STATIC_SUPABASE_URL=
# DGMTS_STATIC_SUPABASE_KEY=
# (If your .env uses DGMTS_STATIC_SUPABASE_PASSWORD for the key, config.py accepts that name too.)
